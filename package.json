{
  "name": "jobsense",
  "version": "0.1.0",
  "private": true,
  "description": "JobSense — Agentic AI Job Search Copilot",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "api:dev": "cd apps/api && uvicorn main:app --reload --port 8000",
    "api:migrate": "cd apps/api && alembic upgrade head",
    "api:seed": "cd apps/api && python scripts/seed.py",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "turbo": "^1.13.3",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
