# =============================================================================
# ApplyFlow — Root Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://applyflow:applyflow@localhost:5432/applyflow
REDIS_URL=redis://localhost:6379/0

# ─── Auth / Security ─────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ─── AI / LLM Providers ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai         # openai | anthropic

# ─── Apify ───────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_...

# ─── Google OAuth + APIs ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── AWS / S3-Compatible Storage ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=applyflow-assets

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development             # development | staging | production
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
